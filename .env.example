PORT=3000
NODE_ENV=development

# Authority login
AUTH_PASSWORD=ChangeThisStrongPassword
AUTH_PIN=2580
SESSION_SECRET=replace-with-a-long-random-string

# Device security
DEVICE_INGEST_TOKEN=replace-with-device-token
ESP32_CAM_CAPTURE_URL=http://192.168.1.88/capture
ESP32_CAM_SHARED_SECRET=replace-with-esp32-shared-secret

# Alert thresholds
LOW_BATTERY_THRESHOLD=25
HIGH_ATTACK_THRESHOLD=80

# Firebase Admin SDK JSON as a single-line string.
# Example: {"type":"service_account","project_id":"..."}
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_STORAGE_BUCKET=

# Firebase Web SDK config for browser Realtime Database listeners
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_DATABASE_URL=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_STORAGE_BUCKET=
FIREBASE_WEB_MESSAGING_SENDER_ID=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_MEASUREMENT_ID=

# Optional Telegram notifications for critical alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
